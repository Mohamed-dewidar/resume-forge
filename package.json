{
  "name": "resume-forge",
  "version": "1.0.0",
  "private": true,
  "description": "Markdown-to-PDF resume builder with ATS-friendly styling and Cursor AI skills for tailoring applications.",
  "scripts": {
    "setup:chrome": "puppeteer browsers install chrome",
    "postinstall": "puppeteer browsers install chrome",
    "build:pdf": "node scripts/build-pdf.js",
    "build:html": "node scripts/build-html.js",
    "build": "node scripts/build-pdf.js && node scripts/build-html.js",
    "build:pdf:custom": "node scripts/build-pdf.js"
  },
  "devDependencies": {
    "dotenv": "^17.4.2",
    "md-to-pdf": "^5.2.4",
    "puppeteer": "^24.0.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "puppeteer"
    ]
  },
  "packageManager": "pnpm@10.15.1+sha512.34e538c329b5553014ca8e8f4535997f96180a1d0f614339357449935350d924e22f8614682191264ec33d1462ac21561aff97f6bb18065351c162c7e8f6de67"
}
